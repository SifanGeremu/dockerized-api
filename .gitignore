# ====================================================================
# DOCKER SPECIFIC
# ====================================================================
# Ignore local Docker override configurations if meant for personal use
docker-compose.override.yml

# Ignore data directories generated by container volumes (e.g., databases)
/data/
/db-data/
.docker-volumes/

# ====================================================================
# NODE.JS / ECOSYSTEM
# ====================================================================
# Dependency directories
node_modules/
jspm_packages/
web_concurrent_snapshots/

# Build and compilation outputs
dist/
build/
.next/
.nuxt/
out/

# TypeScript cache and build info
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# ====================================================================
# SECRETS & ENVIRONMENT VARIABLES
# ====================================================================
# Do NOT commit secrets to Git. Inject these via Docker Compose/K8s.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backup or temporary env files
.env.*.local
*.env

# ====================================================================
# LOGS AND DIAGNOSTICS
# ====================================================================
# NestJS/Express/General logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ====================================================================
# OS & IDE ARTIFACTS
# ====================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
